{
  "manifest_version": 3,
  "name": "스마트누오 샘플 변환기",
  "version": "0.3.0",
  "description": "스마트누오 공유 URL을 요약 샘플 형식으로 변환합니다.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://smartnuo.com/*",
    "https://www.smartnuo.com/*",
    "https://pokeapi.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "샘플 변환기"
  },
  "content_scripts": [
    {
      "matches": ["https://smartnuo.com/*", "https://www.smartnuo.com/*"],
      "js": ["calcFillShared.js", "calcFill.js", "teamBuilderFill.js"],
      "run_at": "document_idle"
    }
  ]
}
